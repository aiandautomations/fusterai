# ── FusterAI Docker Environment ────────────────────────────────────────────────
# Copy to .env and fill in your values before running docker compose up

APP_NAME=FusterAI
APP_ENV=production
APP_KEY=             # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://localhost
APP_HOST=localhost
APP_PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
DB_DATABASE=fusterai
DB_USERNAME=fusterai
DB_PASSWORD=change_me_in_production
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── WebSockets (Reverb) ───────────────────────────────────────────────────────
REVERB_APP_ID=fusterai
REVERB_APP_KEY=change_me_reverb_key
REVERB_APP_SECRET=change_me_reverb_secret
REVERB_PORT=8080

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Search ────────────────────────────────────────────────────────────────────
# Use 'database' for simple setups, 'meilisearch' for full-text search
SCOUT_DRIVER=meilisearch
MEILISEARCH_KEY=change_me_meilisearch_master_key
MEILISEARCH_PORT=7700

# ── Email (outbound) ──────────────────────────────────────────────────────────
# For testing: uses Mailpit (http://localhost:8025)
# For production: set MAIL_MAILER=smtp and configure your SMTP server
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025

# ── Storage (optional S3) ─────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
