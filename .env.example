APP_NAME=FusterAI
APP_ENV=local
APP_KEY=                          # Run: php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost
APP_HOST=localhost
APP_PORT=8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fusterai
DB_USERNAME=fusterai
DB_PASSWORD=secret

# ── Cache / Sessions / Queues (Redis) ─────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ── WebSockets (Reverb) ────────────────────────────────────────────────────────
REVERB_APP_ID=fusterai
REVERB_APP_KEY=your-reverb-key
REVERB_APP_SECRET=your-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── AI ────────────────────────────────────────────────────────────────────────
# Configure your AI provider via Settings → AI Config in the admin panel.
# These .env values are only used as fallbacks if no DB config is saved.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=
# OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_API_KEY=

# AI feature flags — all default to true when an API key is configured
# AI_REPLY_SUGGESTIONS=true
# AI_AUTO_CATEGORIZATION=true
# AI_SUMMARIZATION=true
# AI_RAG=true

# ── Queue Manager (Horizon) ───────────────────────────────────────────────────
HORIZON_DRIVER=redis

# ── Search (MeiliSearch) ───────────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=your-meilisearch-master-key

# ── Mail ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=log                   # Change to smtp in production
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Storage (optional S3) ──────────────────────────────────────────────────────
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# ── Laravel Passport (OAuth 2.1 / MCP) ────────────────────────────────────────
# Generate with: php artisan passport:keys
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
# Set to true when running HTTPS in production
# SESSION_SECURE_COOKIE=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the REST API. Use * in dev only.
CORS_ALLOWED_ORIGINS=*

VITE_APP_NAME="${APP_NAME}"
